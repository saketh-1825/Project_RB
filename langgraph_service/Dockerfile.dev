# langgraph-service/Dockerfile.dev
# Uses uvicorn --reload for hot-reload on file changes.

FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Cache dependencies layer
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

EXPOSE 9000

# --reload watches /app for changes — live source is mounted via docker compose volume
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "9000", "--reload", "--log-level", "debug"]